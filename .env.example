# Local dev — Vite proxies /api to backend
VITE_API_PROXY=http://127.0.0.1:8000

# Optional: override API base (only if not using /api proxy)
# VITE_API_BASE=/api

# Vercel build — backend URL for /api proxy rewrite
# Set this in Vercel Dashboard → Environment Variables
API_PROXY_TARGET=http://3.26.158.53:8000
